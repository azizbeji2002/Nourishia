{% extends 'base.html.twig' %}

{% block title %}Create New Product{% endblock %}

{% block body %}

<div class="row my-5">
    <div class="col-md-10 mx-auto">
        {# Flash messages for success with auto-dismiss #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="background-color: #d4edda; color: #155724; border-left: 5px solid #28a745;">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {# Card for displaying products #}
        <div class="card shadow-lg border-0" style="background-color: #f8f9fa;">
            <div class="card-header text-white d-flex justify-content-between align-items-center" style="background: rgba(126, 58, 242, var(--bg-opacity)); font-size: 1.25rem; padding: 15px;">
                <h5 class="mb-0">liste de Produits</h5>
                <a href="{{ path('app_produit') }}" class="btn btn-lg text-white fw-bold" style="background-color: #17a2b8;">
                    ➕ Add Product
                </a>
            </div>

            <div class="card-body">
                {% if products|length == 0 %}
                    <p class="text-muted fst-italic text-center" style="font-size: 1.2rem;">No products available. Add new products to get started.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-striped table-hover text-center align-middle" style="width: 100%; font-size: 1.2rem;">
                            <thead class="text-white" style="background: linear-gradient(135deg, #5a8dee, #6fc3df); height: 60px;">
                                <tr>
                                   <tr>
    <th style="padding: 15px;">ID</th>
    <th style="padding: 15px;">Name</th>
    <th style="padding: 15px;">Description</th>
        <th style="padding: 15px;">quantite</th>
    <th style="padding: 15px;">Category</th>
    <th style="padding: 15px;">Price</th>
    <th style="padding: 15px;">Image</th>
    <th style="padding: 15px;">Action</th>
</tr>

                                </tr>
                            </thead>
                            <tbody>
                                {% for product in products %}
                                    <tr style="height: 70px;">
                                      
                                        <td>{{ product.id }}</td>
                                        <td class="fw-bold">{{ product.nom }}</td>
<td>{{ product.description }}</td>
<td>{{ product.quantite }}</td>

                                        <td><span class="badge bg-info text-dark" style="font-size: 1rem; padding: 10px;">{{ product.categorie.nom }}</span></td>
                                        <td class="text-success fw-bold">${{ product.prix | number_format(2, '.', ',') }}</td>
                                        <td>
                                            {% if product.image %}
                                                <img src="{{ asset('uploads/' ~ product.image) }}" 
                                                     alt="{{ product.nom }}" 
                                                     class="img-fluid rounded"
                                                     style="width: 80px; height: 80px; object-fit: cover;">
                                            {% else %}
                                                <span class="text-muted">No Image</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('produit_show', { id: product.id }) }}" class="btn btn-sm btn-dark">Show</a>
                                            <a href="{{ path('produit_edit', { id: product.id }) }}" class="btn btn-sm btn-warning">Edit</a>
                                            <a href="{{ path('produit_delete', { id: product.id }) }}" class="btn btn-lg btn-danger">Delete</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>


<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header text-center bg-primary text-white">
                    <h3>Create New Product</h3>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

                    <!-- Form Frame with Border -->
                    <div class="border p-4 rounded-lg shadow-sm">
                        <div class="form-group mb-3">
                            <label for="{{ form.nom.vars.id }}" class="font-weight-bold">Product Name</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label for="{{ form.description.vars.id }}" class="font-weight-bold">Description</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.description, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label for="{{ form.prix.vars.id }}" class="font-weight-bold">Price</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.prix, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label for="{{ form.quantite.vars.id }}" class="font-weight-bold">Quantity</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.quantite, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label for="{{ form.image.vars.id }}" class="font-weight-bold">Product Image (optional)</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.image, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label for="{{ form.categorie.vars.id }}" class="font-weight-bold">Category</label>
                            <div class="border p-3 rounded-lg">
                                {{ form_widget(form.categorie, {'attr': {'class': 'form-control border-0'}}) }}
                            </div>
                        </div>

                        <!-- Styled Submit Button (Blue) -->
                        <div class="text-center">
                            {{ form_row(form.submit, {
                                'attr': {'class': 'btn btn-primary btn-lg rounded-lg mt-3 shadow-sm'}
                            }) }}
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
